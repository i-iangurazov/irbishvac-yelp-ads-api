# Core app
APP_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/yelp_ads_console?schema=public
SESSION_SECRET=replace-with-a-long-random-string
APP_ENCRYPTION_KEY=replace-with-a-separate-long-random-string
CRON_SECRET=replace-with-a-long-random-cron-secret
DEFAULT_TENANT_SLUG=default
DEMO_MODE=false
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_NAME=Admin User
SEED_ADMIN_PASSWORD=replace-with-a-strong-admin-password

# Yelp partner API base URLs
YELP_ADS_BASE_URL=https://partner-api.yelp.com
YELP_FEATURES_BASE_URL=https://partner-api.yelp.com
YELP_REPORTING_BASE_URL=https://api.yelp.com
YELP_BUSINESS_MATCH_BASE_URL=https://partner-api.yelp.com
YELP_DATA_INGESTION_BASE_URL=https://partner-api.yelp.com

# Yelp access and OAuth hints
# Required for live Yelp lead reads, thread replies, mark-read, and reporting pulls.
YELP_CLIENT_ID=
YELP_CLIENT_SECRET=
YELP_ACCESS_TOKEN=
# Legacy fallback name for the same bearer token. Prefer YELP_ACCESS_TOKEN.
YELP_API_KEY=
# OAuth callback only. This is not the Yelp Leads webhook URL.
YELP_REDIRECT_URI=http://localhost:3000/api/yelp/oauth/callback
# Optional comma-separated allowlist of external Yelp business ids.
YELP_ALLOWED_BUSINESS_IDS=

# Optional forwarded-webhook protection
# Set this in both:
# 1. this main app
# 2. the standalone webhook forwarder app
# Leave blank only if Yelp posts directly to this app and you are not using the forwarder.
MAIN_PLATFORM_WEBHOOK_SHARED_SECRET=

# Optional AI-assisted reply drafting and lead summaries in review mode
OPENAI_API_KEY=
# Approved values: gpt-5-nano, gpt-5-mini, gpt-5.2
# Default cheapest/test option:
OPENAI_REPLY_MODEL=gpt-5-nano

# Optional SMTP delivery for recurring reports and masked-email fallback
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=reports@example.com
SMTP_REPLY_TO=

# Optional fresh-db migration verification helpers
# Used by: pnpm prisma:verify:fresh
VERIFY_POSTGRES_URL=
VERIFY_DATABASE_NAME=
VERIFY_KEEP_DB=0
VERIFY_RUN_SEED=0
VERIFY_PSQL_BIN=psql
