generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleCode {
  ADMIN
  OPERATOR
  ANALYST
  VIEWER
}

enum CredentialKind {
  ADS_BASIC_AUTH
  REPORTING_FUSION
  BUSINESS_MATCH
  DATA_INGESTION
  CRM_SERVICETITAN
}

enum ConnectionTestStatus {
  UNTESTED
  SUCCESS
  FAILED
}

enum ProgramType {
  BP
  EP
  CPC
  RCA
  CTA
  SLIDESHOW
  BH
  VL
  LOGO
  PORTFOLIO
}

enum ProgramStatus {
  DRAFT
  QUEUED
  PROCESSING
  ACTIVE
  SCHEDULED
  ENDED
  FAILED
  PARTIAL
}

enum JobType {
  CREATE_PROGRAM
  EDIT_PROGRAM
  END_PROGRAM
  SYNC_JOB
  REQUEST_REPORT
  FETCH_REPORT
  TEST_CONNECTION
}

enum JobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  PARTIAL
  FAILED
}

enum FeatureType {
  LINK_TRACKING
  NEGATIVE_KEYWORD_TARGETING
  STRICT_CATEGORY_TARGETING
  AD_SCHEDULING
  CUSTOM_LOCATION_TARGETING
  AD_GOAL
  CALL_TRACKING
  BUSINESS_HIGHLIGHTS
  VERIFIED_LICENSE
  CUSTOM_RADIUS_TARGETING
  CUSTOM_AD_TEXT
  CUSTOM_AD_PHOTO
  BUSINESS_LOGO
  YELP_PORTFOLIO
}

enum ReportGranularity {
  DAILY
  MONTHLY
}

enum ReportStatus {
  REQUESTED
  PROCESSING
  READY
  FAILED
}

enum AuditStatus {
  PENDING
  SUCCESS
  FAILED
}

enum RecordSourceSystem {
  YELP
  CRM
  INTERNAL
  DERIVED
}

enum YelpLeadReplyState {
  UNKNOWN
  UNREAD
  READ
  REPLIED
}

enum InternalLeadStatus {
  UNMAPPED
  ACTIVE
  NEW
  CONTACTED
  BOOKED
  SCHEDULED
  JOB_IN_PROGRESS
  COMPLETED
  CANCELED
  CLOSED_WON
  CLOSED_LOST
  LOST
}

enum CrmLeadMappingState {
  UNRESOLVED
  MATCHED
  MANUAL_OVERRIDE
  CONFLICT
  ERROR
}

enum SyncRunType {
  YELP_LEADS_WEBHOOK
  YELP_LEADS_BACKFILL
  YELP_REPORTING_REQUEST
  YELP_REPORTING_POLL
  CRM_LEAD_ENRICHMENT
  LOCATION_MAPPING
  SERVICE_MAPPING
}

enum SyncRunStatus {
  QUEUED
  PROCESSING
  COMPLETED
  PARTIAL
  FAILED
  SKIPPED
}

enum ReportingFreshnessState {
  PENDING
  INCOMPLETE
  FINAL
}

enum ReportScheduleCadence {
  WEEKLY
  MONTHLY
}

enum ReportScheduleDeliveryScope {
  ACCOUNT_ONLY
  LOCATION_ONLY
  ACCOUNT_AND_LOCATION
}

enum ReportScheduleRunScope {
  ACCOUNT
  LOCATION
}

enum ReportScheduleGenerationStatus {
  PENDING
  REQUESTED
  PROCESSING
  READY
  FAILED
  SKIPPED
}

enum ReportScheduleDeliveryStatus {
  PENDING
  SENDING
  SENT
  FAILED
  SKIPPED
}

enum LeadAutomationChannel {
  YELP_THREAD
  EMAIL
  PHONE
}

enum LeadAutomationCadence {
  INITIAL
  FOLLOW_UP_24H
  FOLLOW_UP_7D
}

enum LeadAutomationAttemptStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum LeadAutomationSkipReason {
  AUTORESPONDER_DISABLED
  NO_MATCHING_RULE
  TEMPLATE_DISABLED
  MISSING_CONTACT
  OUTSIDE_WORKING_HOURS
  CHANNEL_UNSUPPORTED
  DUPLICATE
  FOLLOW_UP_DISABLED
  CUSTOMER_REPLIED
  HUMAN_TAKEOVER
  LIFECYCLE_STOPPED
  MISSING_THREAD_CONTEXT
}

enum LeadConversationActionType {
  SEND_MESSAGE
  MARK_READ
  MARK_REPLIED
}

enum LeadConversationActionStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum LeadConversationInitiator {
  AUTOMATION
  OPERATOR
  SYSTEM
}

enum OperatorIssueType {
  LEAD_SYNC_FAILURE
  UNMAPPED_LEAD
  CRM_SYNC_FAILURE
  AUTORESPONDER_FAILURE
  REPORT_DELIVERY_FAILURE
  MAPPING_CONFLICT
  STALE_LEAD
}

enum OperatorIssueSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum OperatorIssueStatus {
  OPEN
  RESOLVED
  IGNORED
}

model Tenant {
  id             String              @id @default(cuid())
  name           String
  slug           String              @unique
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  users          User[]
  credentialSets CredentialSet[]
  businesses     Business[]
  programs       Program[]
  programJobs    ProgramJob[]
  programFeatureSnapshots ProgramFeatureSnapshot[]
  reportRequests ReportRequest[]
  reportResults  ReportResult[]
  reportSchedules ReportSchedule[]
  reportScheduleRuns ReportScheduleRun[]
  auditEvents    AuditEvent[]
  settings       SystemSetting[]
  locations      Location[]
  serviceCategories ServiceCategory[]
  yelpLeads      YelpLead[]
  yelpLeadEvents YelpLeadEvent[]
  yelpWebhookEvents YelpWebhookEvent[]
  yelpReportingJobs YelpReportingJob[]
  yelpReportingSnapshots YelpReportingSnapshot[]
  crmLeadMappings CrmLeadMapping[]
  crmStatusEvents CrmStatusEvent[]
  leadAutomationTemplates LeadAutomationTemplate[]
  leadAutomationRules LeadAutomationRule[]
  leadAutomationOverrides LeadAutomationBusinessOverride[]
  leadAutomationAttempts LeadAutomationAttempt[]
  leadConversationActions LeadConversationAction[]
  operatorIssues  OperatorIssue[]
  syncRuns       SyncRun[]
  syncErrors     SyncError[]
}

model Role {
  id              String   @id @default(cuid())
  code            RoleCode @unique
  name            String
  description     String
  permissionsJson Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  users           User[]
}

model User {
  id           String       @id @default(cuid())
  tenantId     String
  roleId       String
  email        String       @unique
  name         String
  passwordHash String
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id])
  reportRuns   ReportRequest[] @relation("ReportCreatedBy")
  auditEvents  AuditEvent[] @relation("AuditActor")
  resolvedOperatorIssues OperatorIssue[] @relation("OperatorIssueResolvedBy")
  ignoredOperatorIssues OperatorIssue[] @relation("OperatorIssueIgnoredBy")

  @@index([tenantId])
  @@index([roleId])
}

model CredentialSet {
  id                 String               @id @default(cuid())
  tenantId           String
  kind               CredentialKind
  label              String
  usernameEncrypted  String?
  secretEncrypted    String
  baseUrl            String?
  isEnabled          Boolean              @default(false)
  lastTestStatus     ConnectionTestStatus @default(UNTESTED)
  lastTestedAt       DateTime?
  lastErrorMessage   String?
  metadataJson       Json?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  tenant             Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, kind])
  @@index([tenantId])
}

model Business {
  id                      String    @id @default(cuid())
  tenantId                String
  locationId              String?
  name                    String
  encryptedYelpBusinessId String
  sourceSystem            RecordSourceSystem @default(YELP)
  city                    String?
  state                   String?
  country                 String?
  categoriesJson          Json      @default("[]")
  readinessJson           Json      @default("{}")
  rawSnapshotJson         Json?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  tenant                  Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  location                Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  mappings                YelpBusinessMapping[]
  programs                Program[]
  programJobs             ProgramJob[]
  featureSnapshots        ProgramFeatureSnapshot[]
  reportRequests          ReportRequest[]
  reportResults           ReportResult[]
  auditEvents             AuditEvent[]
  reportSchedules         ReportSchedule[]
  yelpLeads               YelpLead[]
  leadAutomationTemplates LeadAutomationTemplate[]
  leadAutomationRules     LeadAutomationRule[]
  leadAutomationOverrides LeadAutomationBusinessOverride[]
  leadAutomationAttempts  LeadAutomationAttempt[]
  operatorIssues          OperatorIssue[]
  yelpReportingJobs       YelpReportingJob[]
  yelpReportingSnapshots  YelpReportingSnapshot[]
  syncRuns                SyncRun[]

  @@unique([tenantId, encryptedYelpBusinessId])
  @@index([tenantId, name])
  @@index([locationId])
}

model YelpBusinessMapping {
  id                 String   @id @default(cuid())
  tenantId           String
  businessId         String
  source             String
  externalBusinessId String
  isPrimary          Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  business           Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, externalBusinessId])
  @@index([tenantId])
}

model Program {
  id                String         @id @default(cuid())
  tenantId          String
  businessId        String
  type              ProgramType
  status            ProgramStatus  @default(DRAFT)
  sourceSystem      RecordSourceSystem @default(YELP)
  upstreamProgramId String?
  currency          String         @default("USD")
  budgetCents       Int?
  maxBidCents       Int?
  isAutobid         Boolean?
  pacingMethod      String?
  feePeriod         String?
  startDate         DateTime?
  endDate           DateTime?
  adCategoriesJson  Json?
  configurationJson Json          @default("{}")
  summaryJson       Json?
  lastSyncedAt      DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  business          Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  jobs              ProgramJob[]
  featureSnapshots  ProgramFeatureSnapshot[]
  auditEvents       AuditEvent[]

  @@index([tenantId, businessId])
  @@index([tenantId, type, status])
}

model ProgramJob {
  id                String     @id @default(cuid())
  tenantId          String
  businessId        String
  programId         String?
  type              JobType
  status            JobStatus  @default(QUEUED)
  correlationId     String     @unique
  upstreamJobId     String?
  requestJson       Json?
  responseJson      Json?
  errorJson         Json?
  attempts          Int        @default(0)
  submittedAt       DateTime   @default(now())
  lastPolledAt      DateTime?
  completedAt       DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  tenant            Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  business          Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  program           Program?   @relation(fields: [programId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([programId])
  @@index([businessId])
}

model ProgramFeatureSnapshot {
  id                String      @id @default(cuid())
  tenantId          String
  businessId        String
  programId         String
  type              FeatureType
  isDeleted         Boolean     @default(false)
  valueJson         Json
  capturedAt        DateTime    @default(now())
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  tenant            Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  business          Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  program           Program     @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([tenantId, programId, type])
}

model ReportRequest {
  id                      String            @id @default(cuid())
  tenantId                String
  businessId              String?
  createdById             String?
  granularity             ReportGranularity
  status                  ReportStatus      @default(REQUESTED)
  startDate               DateTime
  endDate                 DateTime
  upstreamRequestId       String?
  requestedBusinessIdsJson Json             @default("[]")
  filtersJson             Json?
  errorJson               Json?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  tenant                  Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  business                Business?         @relation(fields: [businessId], references: [id], onDelete: SetNull)
  createdBy               User?             @relation("ReportCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  results                 ReportResult[]
  reportScheduleRuns      ReportScheduleRun[]
  operatorIssues          OperatorIssue[]
  auditEvents             AuditEvent[]

  @@index([tenantId, status, granularity])
  @@index([businessId])
}

model ReportResult {
  id                 String      @id @default(cuid())
  tenantId           String
  reportRequestId    String
  businessId         String?
  granularity        ReportGranularity
  cacheKey           String      @unique
  payloadJson        Json
  metricsSummaryJson Json?
  rawStatus          String?
  fetchedAt          DateTime    @default(now())
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  tenant             Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reportRequest      ReportRequest @relation(fields: [reportRequestId], references: [id], onDelete: Cascade)
  business           Business?   @relation(fields: [businessId], references: [id], onDelete: SetNull)

  @@index([tenantId, reportRequestId])
}

model ReportSchedule {
  id                        String               @id @default(cuid())
  tenantId                  String
  businessId                String?
  name                      String
  cadence                   ReportScheduleCadence
  deliveryScope             ReportScheduleDeliveryScope @default(ACCOUNT_ONLY)
  timezone                  String
  sendDayOfWeek             Int?
  sendDayOfMonth            Int?
  sendHour                  Int
  sendMinute                Int                @default(0)
  deliverPerLocation        Boolean            @default(false)
  recipientEmailsJson       Json               @default("[]")
  locationRecipientOverridesJson Json          @default("[]")
  isEnabled                 Boolean            @default(true)
  lastTriggeredAt           DateTime?
  lastSuccessfulGenerationAt DateTime?
  lastSuccessfulDeliveryAt  DateTime?
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt
  tenant                    Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  business                  Business?          @relation(fields: [businessId], references: [id], onDelete: SetNull)
  runs                      ReportScheduleRun[]

  @@index([tenantId, isEnabled, cadence])
  @@index([businessId])
}

model ReportScheduleRun {
  id                  String                      @id @default(cuid())
  runKey              String                      @unique
  tenantId            String
  scheduleId          String
  reportRequestId     String?
  locationId          String?
  scope               ReportScheduleRunScope
  scopeKey            String
  windowStart         DateTime
  windowEnd           DateTime
  scheduledFor        DateTime
  generationStatus    ReportScheduleGenerationStatus @default(PENDING)
  deliveryStatus      ReportScheduleDeliveryStatus   @default(PENDING)
  recipientEmailsJson Json                        @default("[]")
  recipientContextJson Json                       @default("{}")
  dashboardUrl        String?
  summaryJson         Json?
  generationStartedAt DateTime?
  generatedAt         DateTime?
  deliveryStartedAt   DateTime?
  deliveredAt         DateTime?
  lastAttemptedAt     DateTime?
  errorSummary        String?
  errorJson           Json?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  tenant              Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  schedule            ReportSchedule              @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  reportRequest       ReportRequest?              @relation(fields: [reportRequestId], references: [id], onDelete: SetNull)
  location            Location?                   @relation(fields: [locationId], references: [id], onDelete: SetNull)
  operatorIssues      OperatorIssue[]

  @@index([tenantId, generationStatus, deliveryStatus])
  @@index([scheduleId, scheduledFor])
  @@index([reportRequestId, locationId])
}

model AuditEvent {
  id                    String      @id @default(cuid())
  tenantId              String
  actorId               String?
  businessId            String?
  programId             String?
  reportRequestId       String?
  actionType            String
  status                AuditStatus @default(PENDING)
  correlationId         String?
  upstreamReference     String?
  requestSummaryJson    Json?
  responseSummaryJson   Json?
  beforeJson            Json?
  afterJson             Json?
  rawPayloadSummaryJson Json?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  tenant                Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor                 User?       @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  business              Business?   @relation(fields: [businessId], references: [id], onDelete: SetNull)
  program               Program?    @relation(fields: [programId], references: [id], onDelete: SetNull)
  reportRequest         ReportRequest? @relation(fields: [reportRequestId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([actorId])
  @@index([businessId])
  @@index([programId])
}

model Location {
  id                  String             @id @default(cuid())
  tenantId            String
  name                String
  code                String?
  externalCrmLocationId String?
  timezone            String?
  city                String?
  state               String?
  country             String?
  isActive            Boolean            @default(true)
  sourceSystem        RecordSourceSystem @default(INTERNAL)
  metadataJson        Json?
  rawSnapshotJson     Json?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  tenant              Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  businesses          Business[]
  reportScheduleRuns  ReportScheduleRun[]
  leadAutomationRules LeadAutomationRule[]
  leadAutomationAttempts LeadAutomationAttempt[]
  operatorIssues      OperatorIssue[]
  yelpLeads           YelpLead[]
  yelpReportingJobs   YelpReportingJob[]
  yelpReportingSnapshots YelpReportingSnapshot[]
  crmLeadMappings     CrmLeadMapping[]
  crmStatusEvents     CrmStatusEvent[]
  syncRuns            SyncRun[]

  @@unique([tenantId, externalCrmLocationId])
  @@index([tenantId, name])
  @@index([tenantId, isActive])
}

model ServiceCategory {
  id               String             @id @default(cuid())
  tenantId         String
  name             String
  slug             String
  sourceSystem     RecordSourceSystem @default(INTERNAL)
  yelpAliasesJson  Json               @default("[]")
  crmCodesJson     Json               @default("[]")
  mappingRulesJson Json               @default("[]")
  metadataJson     Json?
  rawSnapshotJson  Json?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leadAutomationRules LeadAutomationRule[]
  leadAutomationAttempts LeadAutomationAttempt[]
  yelpLeads        YelpLead[]
  yelpReportingSnapshots YelpReportingSnapshot[]

  @@unique([tenantId, slug])
  @@index([tenantId, name])
}

model YelpLead {
  id                    String             @id @default(cuid())
  tenantId              String
  businessId            String?
  locationId            String?
  serviceCategoryId     String?
  externalLeadId        String
  externalBusinessId    String?
  externalConversationId String?
  sourceSystem          RecordSourceSystem @default(YELP)
  customerName          String?
  customerEmail         String?
  customerPhone         String?
  createdAtYelp         DateTime
  latestInteractionAt   DateTime?
  replyState            YelpLeadReplyState @default(UNKNOWN)
  readAt                DateTime?
  repliedAt             DateTime?
  internalStatus        InternalLeadStatus @default(UNMAPPED)
  mappedServiceLabel    String?
  metadataJson          Json?
  rawSnapshotJson       Json?
  firstSeenAt           DateTime           @default(now())
  lastSyncedAt          DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  tenant                Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  business              Business?          @relation(fields: [businessId], references: [id], onDelete: SetNull)
  location              Location?          @relation(fields: [locationId], references: [id], onDelete: SetNull)
  serviceCategory       ServiceCategory?   @relation(fields: [serviceCategoryId], references: [id], onDelete: SetNull)
  events                YelpLeadEvent[]
  webhookEvents         YelpWebhookEvent[]
  crmLeadMappings       CrmLeadMapping[]
  crmStatusEvents       CrmStatusEvent[]
  automationAttempts    LeadAutomationAttempt[]
  conversationActions   LeadConversationAction[]
  operatorIssues        OperatorIssue[]
  syncRuns              SyncRun[]

  @@unique([tenantId, externalLeadId])
  @@index([tenantId, createdAtYelp])
  @@index([tenantId, internalStatus])
  @@index([businessId, locationId, serviceCategoryId])
}

model YelpLeadEvent {
  id              String             @id @default(cuid())
  tenantId        String
  leadId          String
  eventKey        String
  externalEventId String?
  eventType       String
  actorType       String?
  occurredAt      DateTime?
  isRead          Boolean            @default(false)
  isReply         Boolean            @default(false)
  sourceSystem    RecordSourceSystem @default(YELP)
  payloadJson     Json
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead            YelpLead           @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([tenantId, eventKey])
  @@index([tenantId, leadId, occurredAt])
  @@index([tenantId, externalEventId])
}

model YelpWebhookEvent {
  id                String             @id @default(cuid())
  tenantId          String
  leadId            String?
  syncRunId         String?
  eventKey          String
  deliveryId        String?
  topic             String
  status            SyncRunStatus      @default(QUEUED)
  signatureVerified Boolean            @default(false)
  sourceSystem      RecordSourceSystem @default(YELP)
  receivedAt        DateTime           @default(now())
  processedAt       DateTime?
  headersJson       Json?
  payloadJson       Json
  errorJson         Json?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead              YelpLead?          @relation(fields: [leadId], references: [id], onDelete: SetNull)
  syncRun           SyncRun?           @relation(fields: [syncRunId], references: [id], onDelete: SetNull)

  @@unique([tenantId, eventKey])
  @@index([tenantId, topic, receivedAt])
  @@index([tenantId, deliveryId])
}

model YelpReportingJob {
  id                  String                 @id @default(cuid())
  tenantId            String
  businessId          String?
  locationId          String?
  granularity         ReportGranularity
  status              ReportStatus           @default(REQUESTED)
  upstreamJobId       String?
  sourceSystem        RecordSourceSystem     @default(YELP)
  requestScopeJson    Json?
  requestJson         Json?
  responseJson        Json?
  freshnessAsOf       DateTime?
  lastSuccessfulSyncAt DateTime?
  lastPolledAt        DateTime?
  completedAt         DateTime?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  tenant              Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  business            Business?              @relation(fields: [businessId], references: [id], onDelete: SetNull)
  location            Location?              @relation(fields: [locationId], references: [id], onDelete: SetNull)
  snapshots           YelpReportingSnapshot[]
  syncRuns            SyncRun[]

  @@unique([tenantId, upstreamJobId])
  @@index([tenantId, status, granularity])
  @@index([businessId, locationId])
}

model YelpReportingSnapshot {
  id                  String                 @id @default(cuid())
  tenantId            String
  reportingJobId      String
  businessId          String?
  locationId          String?
  serviceCategoryId   String?
  sourceSystem        RecordSourceSystem     @default(YELP)
  windowStart         DateTime
  windowEnd           DateTime
  freshnessState      ReportingFreshnessState @default(PENDING)
  lastSuccessfulSyncAt DateTime?
  payloadJson         Json
  metricsSummaryJson  Json?
  rawStatus           String?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  tenant              Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reportingJob        YelpReportingJob       @relation(fields: [reportingJobId], references: [id], onDelete: Cascade)
  business            Business?              @relation(fields: [businessId], references: [id], onDelete: SetNull)
  location            Location?              @relation(fields: [locationId], references: [id], onDelete: SetNull)
  serviceCategory     ServiceCategory?       @relation(fields: [serviceCategoryId], references: [id], onDelete: SetNull)

  @@index([tenantId, windowStart, windowEnd])
  @@index([businessId, locationId, serviceCategoryId])
}

model CrmLeadMapping {
  id                 String             @id @default(cuid())
  tenantId           String
  leadId             String
  locationId         String?
  externalCrmLeadId  String?
  externalOpportunityId String?
  externalJobId      String?
  state              CrmLeadMappingState @default(UNRESOLVED)
  matchMethod        String?
  confidenceScore    Float?
  sourceSystem       RecordSourceSystem @default(CRM)
  matchedAt          DateTime?
  issueSummary       String?
  lastSyncedAt       DateTime?
  metadataJson       Json?
  rawSnapshotJson    Json?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  tenant             Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead               YelpLead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  location           Location?          @relation(fields: [locationId], references: [id], onDelete: SetNull)
  statusEvents       CrmStatusEvent[]

  @@unique([leadId])
  @@unique([tenantId, externalCrmLeadId])
  @@index([tenantId, state])
  @@index([tenantId, locationId])
}

model CrmStatusEvent {
  id                  String             @id @default(cuid())
  tenantId            String
  leadId              String
  crmLeadMappingId    String?
  locationId          String?
  externalStatusEventId String?
  status              InternalLeadStatus
  substatus           String?
  sourceSystem        RecordSourceSystem @default(CRM)
  occurredAt          DateTime
  payloadJson         Json
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  tenant              Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead                YelpLead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  crmLeadMapping      CrmLeadMapping?    @relation(fields: [crmLeadMappingId], references: [id], onDelete: SetNull)
  location            Location?          @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@unique([tenantId, externalStatusEventId])
  @@index([tenantId, leadId, occurredAt])
  @@index([tenantId, status])
}

model LeadAutomationTemplate {
  id              String                @id @default(cuid())
  tenantId        String
  businessId      String?
  name            String
  channel         LeadAutomationChannel
  isEnabled       Boolean               @default(true)
  subjectTemplate String?
  bodyTemplate    String
  sourceSystem    RecordSourceSystem    @default(INTERNAL)
  metadataJson    Json?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  tenant          Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  business        Business?             @relation(fields: [businessId], references: [id], onDelete: SetNull)
  rules           LeadAutomationRule[]
  attempts        LeadAutomationAttempt[]

  @@index([tenantId, channel, isEnabled])
  @@index([tenantId, businessId, channel, isEnabled])
  @@index([tenantId, name])
}

model LeadAutomationRule {
  id                     String                @id @default(cuid())
  tenantId               String
  templateId             String
  businessId             String?
  locationId             String?
  serviceCategoryId      String?
  name                   String
  channel                LeadAutomationChannel
  cadence                LeadAutomationCadence @default(INITIAL)
  isEnabled              Boolean               @default(true)
  priority               Int                   @default(100)
  onlyDuringWorkingHours Boolean               @default(false)
  timezone               String?
  workingDaysJson        Json                  @default("[1,2,3,4,5]")
  startMinute            Int?
  endMinute              Int?
  sourceSystem           RecordSourceSystem    @default(INTERNAL)
  metadataJson           Json?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  tenant                 Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template               LeadAutomationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  business               Business?              @relation(fields: [businessId], references: [id], onDelete: SetNull)
  location               Location?             @relation(fields: [locationId], references: [id], onDelete: SetNull)
  serviceCategory        ServiceCategory?      @relation(fields: [serviceCategoryId], references: [id], onDelete: SetNull)
  attempts               LeadAutomationAttempt[]

  @@index([tenantId, cadence, isEnabled, priority])
  @@index([tenantId, businessId, locationId, serviceCategoryId, cadence])
}

model LeadAutomationBusinessOverride {
  id                  String                @id @default(cuid())
  tenantId            String
  businessId          String
  isEnabled           Boolean               @default(true)
  defaultChannel      LeadAutomationChannel @default(YELP_THREAD)
  emailFallbackEnabled Boolean              @default(true)
  followUp24hEnabled  Boolean               @default(false)
  followUp24hDelayHours Int                 @default(24)
  followUp7dEnabled   Boolean               @default(false)
  followUp7dDelayDays Int                   @default(7)
  aiAssistEnabled     Boolean               @default(true)
  aiModel             String                @default("gpt-5-nano")
  metadataJson        Json?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  tenant              Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  business            Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([tenantId, businessId])
  @@index([tenantId, businessId])
}

model LeadAutomationAttempt {
  id                  String                     @id @default(cuid())
  tenantId            String
  leadId              String
  businessId          String?
  locationId          String?
  serviceCategoryId   String?
  ruleId              String?
  templateId          String?
  channel             LeadAutomationChannel?
  cadence             LeadAutomationCadence     @default(INITIAL)
  status              LeadAutomationAttemptStatus @default(PENDING)
  skipReason          LeadAutomationSkipReason?
  sourceSystem        RecordSourceSystem         @default(INTERNAL)
  recipient           String?
  renderedSubject     String?
  renderedBody        String?
  providerMessageId   String?
  providerStatus      String?
  providerMetadataJson Json?
  errorSummary        String?
  triggeredAt         DateTime                   @default(now())
  dueAt               DateTime?
  startedAt           DateTime?
  completedAt         DateTime?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  tenant              Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead                YelpLead                    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  business            Business?                   @relation(fields: [businessId], references: [id], onDelete: SetNull)
  location            Location?                   @relation(fields: [locationId], references: [id], onDelete: SetNull)
  serviceCategory     ServiceCategory?            @relation(fields: [serviceCategoryId], references: [id], onDelete: SetNull)
  rule                LeadAutomationRule?         @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  template            LeadAutomationTemplate?     @relation(fields: [templateId], references: [id], onDelete: SetNull)
  conversationActions LeadConversationAction[]

  @@unique([leadId, cadence])
  @@index([tenantId, cadence, status, dueAt])
  @@index([tenantId, status, triggeredAt])
  @@index([tenantId, businessId, locationId, serviceCategoryId])
}

model LeadConversationAction {
  id                   String                       @id @default(cuid())
  tenantId             String
  leadId               String
  automationAttemptId  String?
  actorId              String?
  initiator            LeadConversationInitiator
  actionType           LeadConversationActionType
  channel              LeadAutomationChannel
  status               LeadConversationActionStatus @default(PENDING)
  sourceSystem         RecordSourceSystem          @default(INTERNAL)
  recipient            String?
  renderedSubject      String?
  renderedBody         String?
  providerMessageId    String?
  providerStatus       String?
  providerMetadataJson Json?
  errorSummary         String?
  startedAt            DateTime?
  completedAt          DateTime?
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt
  tenant               Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead                 YelpLead                    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  automationAttempt    LeadAutomationAttempt?      @relation(fields: [automationAttemptId], references: [id], onDelete: SetNull)

  @@index([tenantId, leadId, createdAt])
  @@index([tenantId, status, createdAt])
  @@index([tenantId, automationAttemptId])
}

model OperatorIssue {
  id                  String                @id @default(cuid())
  tenantId            String
  businessId          String?
  locationId          String?
  leadId              String?
  reportRequestId     String?
  reportScheduleRunId String?
  syncRunId           String?
  issueType           OperatorIssueType
  severity            OperatorIssueSeverity
  status              OperatorIssueStatus   @default(OPEN)
  dedupeKey           String
  sourceSystem        RecordSourceSystem    @default(DERIVED)
  title               String
  summary             String
  detailsJson         Json?
  detectedCount       Int                   @default(1)
  firstDetectedAt     DateTime              @default(now())
  lastDetectedAt      DateTime              @default(now())
  resolvedAt          DateTime?
  resolvedById        String?
  resolutionReason    String?
  resolutionNote      String?
  ignoredAt           DateTime?
  ignoredById         String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  tenant              Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  business            Business?             @relation(fields: [businessId], references: [id], onDelete: SetNull)
  location            Location?             @relation(fields: [locationId], references: [id], onDelete: SetNull)
  lead                YelpLead?             @relation(fields: [leadId], references: [id], onDelete: SetNull)
  reportRequest       ReportRequest?        @relation(fields: [reportRequestId], references: [id], onDelete: SetNull)
  reportScheduleRun   ReportScheduleRun?    @relation(fields: [reportScheduleRunId], references: [id], onDelete: SetNull)
  syncRun             SyncRun?              @relation(fields: [syncRunId], references: [id], onDelete: SetNull)
  resolvedBy          User?                 @relation("OperatorIssueResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)
  ignoredBy           User?                 @relation("OperatorIssueIgnoredBy", fields: [ignoredById], references: [id], onDelete: SetNull)

  @@unique([tenantId, dedupeKey])
  @@index([tenantId, status, severity, lastDetectedAt])
  @@index([businessId, locationId, leadId, reportRequestId, reportScheduleRunId, syncRunId])
}

model SyncRun {
  id                  String             @id @default(cuid())
  tenantId            String
  businessId          String?
  locationId          String?
  leadId              String?
  reportingJobId      String?
  type                SyncRunType
  status              SyncRunStatus      @default(QUEUED)
  sourceSystem        RecordSourceSystem
  capabilityKey       String?
  correlationId       String?
  startedAt           DateTime           @default(now())
  finishedAt          DateTime?
  lastSuccessfulSyncAt DateTime?
  statsJson           Json?
  requestJson         Json?
  responseJson        Json?
  errorSummary        String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  tenant              Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  business            Business?          @relation(fields: [businessId], references: [id], onDelete: SetNull)
  location            Location?          @relation(fields: [locationId], references: [id], onDelete: SetNull)
  lead                YelpLead?          @relation(fields: [leadId], references: [id], onDelete: SetNull)
  reportingJob        YelpReportingJob?  @relation(fields: [reportingJobId], references: [id], onDelete: SetNull)
  operatorIssues      OperatorIssue[]
  webhookEvents       YelpWebhookEvent[]
  errors              SyncError[]

  @@index([tenantId, type, status])
  @@index([tenantId, startedAt])
  @@index([businessId, locationId, leadId, reportingJobId])
}

model SyncError {
  id           String             @id @default(cuid())
  tenantId     String
  syncRunId    String
  sourceSystem RecordSourceSystem
  category     String
  code         String?
  message      String
  isRetryable  Boolean            @default(true)
  detailsJson  Json?
  occurredAt   DateTime           @default(now())
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  syncRun      SyncRun            @relation(fields: [syncRunId], references: [id], onDelete: Cascade)

  @@index([tenantId, occurredAt])
  @@index([syncRunId])
}

model SystemSetting {
  id        String   @id @default(cuid())
  tenantId  String
  key       String
  valueJson Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId])
}
